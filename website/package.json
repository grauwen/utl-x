{
  "name": "utlx-lang-site",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "utlx-lang.org — UTL-X language reference + book (VitePress static site)",
  "scripts": {
    "convert": "./scripts/convert-book.sh",
    "stdlib": "node ./scripts/build-stdlib.mjs",
    "content": "npm run convert && npm run stdlib",
    "dev": "vitepress dev",
    "build": "vitepress build",
    "build:ide": "DOCS_BASE=/utlx-docs/ DOCS_OUTDIR=.vitepress/dist-ide vitepress build && node ./scripts/fix-ide-base.mjs",
    "preview": "vitepress preview"
  },
  "devDependencies": {
    "vitepress": "^1.6.3"
  }
}
