{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Order",
  "description": "Order document (source 1 of 2).",
  "type": "object",
  "required": ["orderId", "orderDate", "customerId", "currency", "totalAmount", "lines"],
  "properties": {
    "orderId":     { "type": "string" },
    "orderDate":   { "type": "string", "format": "date" },
    "customerId":  { "type": "string", "description": "Join key to the customer master" },
    "currency":    { "type": "string" },
    "totalAmount": { "type": "number" },
    "lines": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["sku", "quantity", "unitPrice"],
        "properties": {
          "sku":       { "type": "string" },
          "quantity":  { "type": "integer" },
          "unitPrice": { "type": "number" }
        }
      }
    }
  }
}
