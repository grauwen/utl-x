<?xml version="1.0" encoding="utf-8"?>
<!-- Source 1 of 3 (OData instance, OSch/EDMX schema): the employee master.
     OData property names are PascalCase; coverage matches them case-insensitively. -->
<edmx:Edmx Version="4.0" xmlns:edmx="http://docs.oasis-open.org/odata/ns/edmx">
  <edmx:DataServices>
    <Schema Namespace="HR.Model" xmlns="http://docs.oasis-open.org/odata/ns/edm">
      <EntityType Name="Employee">
        <Key>
          <PropertyRef Name="EmployeeID"/>
        </Key>
        <Property Name="EmployeeID" Type="Edm.String" Nullable="false"/>
        <Property Name="FirstName" Type="Edm.String" Nullable="false"/>
        <Property Name="LastName" Type="Edm.String" Nullable="false"/>
        <Property Name="DepartmentID" Type="Edm.String"/>
        <Property Name="HireDate" Type="Edm.Date"/>
      </EntityType>
      <EntityContainer Name="HRContainer">
        <EntitySet Name="Employees" EntityType="HR.Model.Employee"/>
      </EntityContainer>
    </Schema>
  </edmx:DataServices>
</edmx:Edmx>
