{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "invoice",
  "type": "object",
  "properties": {
    "invoice": {
      "type": "object",
      "properties": {
        "orderId": {
          "type": "string"
        },
        "billTo": {
          "type": "string"
        },
        "lines": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "sku": {
                "type": "string"
              },
              "quantity": {
                "type": "integer"
              },
              "unitPrice": {
                "type": "integer"
              },
              "lineTotal": {
                "type": "number"
              }
            },
            "required": [
              "sku",
              "quantity",
              "unitPrice",
              "lineTotal"
            ]
          }
        },
        "subtotal": {
          "type": "number"
        },
        "currency": {
          "type": "string"
        }
      },
      "required": [
        "orderId",
        "lines",
        "subtotal"
      ]
    }
  },
  "required": [
    "invoice"
  ]
}
