{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "fraudCheck",
  "type": "object",
  "properties": {
    "approved": {
      "type": "boolean"
    },
    "riskScore": {
      "type": "number"
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "approved",
    "riskScore",
    "checks",
    "timestamp"
  ]
}
