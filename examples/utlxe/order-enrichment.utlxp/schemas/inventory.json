{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "inventory",
  "type": "object",
  "properties": {
    "products": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "sku": {
            "type": "string"
          },
          "productName": {
            "type": "string"
          },
          "quantityOnHand": {
            "type": "integer"
          },
          "warehouse": {
            "type": "string"
          },
          "reorderPoint": {
            "type": "integer"
          }
        },
        "required": [
          "sku",
          "productName",
          "quantityOnHand",
          "warehouse",
          "reorderPoint"
        ]
      }
    }
  },
  "required": [
    "products"
  ]
}
