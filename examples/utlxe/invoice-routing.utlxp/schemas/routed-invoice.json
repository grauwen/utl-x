{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "routed-invoice",
  "description": "Output contract produced by route-invoice.utlx.",
  "type": "object",
  "required": ["invoiceId", "customerName", "total", "destination"],
  "properties": {
    "invoiceId": { "type": "string" },
    "customerName": { "type": "string" },
    "currency": { "type": "string" },
    "total": { "type": "number" },
    "destination": { "type": "string", "enum": ["priority-queue", "standard-queue"] }
  }
}
