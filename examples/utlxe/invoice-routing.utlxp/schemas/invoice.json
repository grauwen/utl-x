{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "invoice",
  "type": "object",
  "properties": {
    "invoiceId": {
      "type": "string"
    },
    "customer": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "name"
      ]
    },
    "currency": {
      "type": "string"
    },
    "total": {
      "type": "number"
    },
    "lines": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "sku": {
            "type": "string"
          },
          "qty": {
            "type": "integer"
          },
          "price": {
            "type": "integer"
          }
        },
        "required": [
          "sku",
          "qty",
          "price"
        ]
      }
    }
  },
  "required": [
    "invoiceId",
    "customer",
    "currency",
    "total",
    "lines"
  ]
}
