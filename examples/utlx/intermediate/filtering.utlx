// Filtering example
%utlx 1.0
input json
output json
---
{
  highValueOrders: $input.orders
    |> filter(order => order.total > 1000)
    |> sortBy(order => order.total)
    |> take(10),

  vipCustomers: $input.customers
    |> filter(customer => customer.tier == "VIP" && customer.active == true)
    |> map(customer => {
         id: customer.id,
         name: customer.name,
         email: customer.email
       })
}
