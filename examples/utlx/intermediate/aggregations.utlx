// Aggregation example
%utlx 1.0
input json
output json
---
{
  summary: {
    totalOrders: count($input.orders),
    totalRevenue: sum($input.orders |> map(o => o.total)),
    avgOrderValue: avg($input.orders |> map(o => o.total)),
    maxOrder: max($input.orders |> map(o => o.total)),
    minOrder: min($input.orders |> map(o => o.total))
  },

  byCustomer: $input.orders
    |> groupBy(order => order.customerId)
}
